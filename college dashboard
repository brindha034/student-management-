<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
  *{box-sizing:border-box;margin:0;padding:0}
  :root{
    --bg:#f8f9ff;--sidebar:#ffffff;--card:#ffffff;--border:#e8eaf6;
    --text:#1a1d3b;--muted:#6b7280;--accent1:#4f46e5;--accent2:#7c3aed;
    --accent3:#2563eb;--success:#059669;--warning:#d97706;--danger:#dc2626;
    --grad:linear-gradient(135deg,#4f46e5,#7c3aed);
    --grad2:linear-gradient(135deg,#2563eb,#4f46e5);
    --shadow:0 2px 16px rgba(79,70,229,0.08);
    --radius:12px;--radius-sm:8px;
  }
  body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex}
  .sidebar{width:240px;min-height:100vh;background:var(--sidebar);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;left:0;top:0;bottom:0;z-index:100;transition:.3s}
  .logo{padding:20px 20px 16px;border-bottom:1px solid var(--border)}
  .logo-inner{display:flex;align-items:center;gap:10px}
  .logo-icon{width:36px;height:36px;border-radius:10px;background:var(--grad);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:14px}
  .logo-text{font-weight:700;font-size:15px;color:var(--text)}
  .logo-sub{font-size:10px;color:var(--muted)}
  .role-switch{padding:12px 16px;border-bottom:1px solid var(--border)}
  .role-btn{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-radius:var(--radius-sm);border:1px solid var(--border);cursor:pointer;background:var(--bg);font-size:12px;font-weight:500;width:100%;transition:.2s}
  .role-btn:hover{border-color:var(--accent1)}
  .role-tag{padding:2px 8px;border-radius:20px;font-size:10px;font-weight:600}
  .tag-student{background:#ede9fe;color:#6d28d9}
  .tag-staff{background:#dbeafe;color:#1d4ed8}
  .tag-admin{background:#fce7f3;color:#be185d}
  .nav{flex:1;padding:12px 0;overflow-y:auto}
  .nav-section{padding:0 16px;margin-bottom:4px}
  .nav-label{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin:8px 0 4px}
  .nav-item{display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:var(--radius-sm);cursor:pointer;transition:.2s;font-size:13px;font-weight:500;color:var(--muted);margin-bottom:2px;position:relative}
  .nav-item:hover{background:#f3f4f6;color:var(--text)}
  .nav-item.active{background:#ede9fe;color:var(--accent1)}
  .nav-item .icon{width:18px;height:18px;display:flex;align-items:center;justify-content:center;font-size:15px}
  .nav-badge{margin-left:auto;background:#ef4444;color:#fff;font-size:9px;padding:2px 6px;border-radius:10px;font-weight:600}
  .sidebar-user{padding:16px;border-top:1px solid var(--border)}
  .user-card{display:flex;align-items:center;gap:10px}
  .avatar{width:36px;height:36px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600;font-size:13px;flex-shrink:0}
  .user-info .name{font-size:13px;font-weight:600}
  .user-info .id{font-size:11px;color:var(--muted)}
  .main{margin-left:240px;flex:1;padding:24px;min-height:100vh}
  .topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px}
  .page-title{font-size:22px;font-weight:700}
  .page-sub{font-size:13px;color:var(--muted);margin-top:2px}
  .topbar-right{display:flex;align-items:center;gap:12px}
  .btn{padding:8px 16px;border-radius:var(--radius-sm);border:none;cursor:pointer;font-size:13px;font-weight:500;transition:.2s;display:inline-flex;align-items:center;gap:6px}
  .btn-primary{background:var(--grad);color:#fff}
  .btn-primary:hover{opacity:.9}
  .btn-ghost{background:var(--card);border:1px solid var(--border);color:var(--text)}
  .btn-ghost:hover{border-color:var(--accent1);color:var(--accent1)}
  .notif-btn{position:relative;width:36px;height:36px;border-radius:var(--radius-sm);background:var(--card);border:1px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px}
  .notif-dot{position:absolute;top:6px;right:6px;width:8px;height:8px;background:#ef4444;border-radius:50%;border:2px solid #fff}
  .grid{display:grid;gap:16px}
  .grid-4{grid-template-columns:repeat(4,1fr)}
  .grid-3{grid-template-columns:repeat(3,1fr)}
  .grid-2{grid-template-columns:repeat(2,1fr)}
  .card{background:var(--card);border-radius:var(--radius);border:1px solid var(--border);padding:20px;box-shadow:var(--shadow);transition:.2s}
  .card:hover{box-shadow:0 4px 24px rgba(79,70,229,0.12)}
  .stat-card{position:relative;overflow:hidden}
  .stat-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:12px}
  .stat-val{font-size:28px;font-weight:700;line-height:1}
  .stat-label{font-size:12px;color:var(--muted);margin-top:4px;font-weight:500}
  .stat-trend{font-size:11px;margin-top:8px;display:flex;align-items:center;gap:4px}
  .trend-up{color:var(--success)}
  .trend-dn{color:var(--danger)}
  .card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
  .card-title{font-size:14px;font-weight:600}
  .badge{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}
  .badge-success{background:#d1fae5;color:#065f46}
  .badge-warning{background:#fef3c7;color:#92400e}
  .badge-danger{background:#fee2e2;color:#991b1b}
  .badge-info{background:#dbeafe;color:#1e40af}
  .badge-purple{background:#ede9fe;color:#5b21b6}
  .progress-bar{height:8px;background:#f3f4f6;border-radius:20px;overflow:hidden}
  .progress-fill{height:100%;border-radius:20px;transition:.6s}
  .fill-green{background:linear-gradient(90deg,#10b981,#34d399)}
  .fill-blue{background:var(--grad2)}
  .fill-purple{background:var(--grad)}
  .fill-amber{background:linear-gradient(90deg,#f59e0b,#fcd34d)}
  .fill-red{background:linear-gradient(90deg,#ef4444,#f87171)}
  .table-wrap{overflow-x:auto}
  table{width:100%;border-collapse:collapse;font-size:13px}
  th{text-align:left;font-weight:600;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px;padding:8px 12px;border-bottom:1px solid var(--border)}
  td{padding:10px 12px;border-bottom:1px solid var(--border)}
  tr:last-child td{border-bottom:none}
  tr:hover td{background:#fafbff}
  .att-pct{font-weight:700;font-size:13px}
  .att-high{color:var(--success)}
  .att-low{color:var(--danger)}
  .att-mid{color:var(--warning)}
  .calendar{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
  .cal-day{width:100%;aspect-ratio:1;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:500;cursor:pointer;transition:.15s}
  .cal-p{background:#d1fae5;color:#065f46}
  .cal-a{background:#fee2e2;color:#991b1b}
  .cal-h{background:#f3f4f6;color:#9ca3af}
  .cal-t{background:var(--grad);color:#fff;box-shadow:0 2px 8px rgba(79,70,229,.3)}
  .cal-header{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:4px}
  .cal-dname{text-align:center;font-size:10px;font-weight:600;color:var(--muted)}
  .subject-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border)}
  .subject-row:last-child{border-bottom:none}
  .subject-name{font-size:13px;font-weight:500}
  .subject-code{font-size:11px;color:var(--muted)}
  .ai-chat{display:flex;flex-direction:column;height:300px}
  .chat-msgs{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:10px;margin-bottom:12px;padding:4px}
  .msg{padding:10px 14px;border-radius:var(--radius);max-width:85%;font-size:13px;line-height:1.5}
  .msg-bot{background:#ede9fe;color:#4c1d95;align-self:flex-start}
  .msg-user{background:var(--grad);color:#fff;align-self:flex-end}
  .chat-input{display:flex;gap:8px}
  .chat-input input{flex:1;padding:8px 14px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:13px;outline:none;font-family:inherit}
  .chat-input input:focus{border-color:var(--accent1)}
  .typing{display:flex;gap:4px;align-items:center;padding:10px 14px;background:#ede9fe;border-radius:var(--radius);width:60px;align-self:flex-start}
  .dot{width:6px;height:6px;background:#7c3aed;border-radius:50%;animation:bounce .8s infinite}
  .dot:nth-child(2){animation-delay:.15s}
  .dot:nth-child(3){animation-delay:.3s}
  @keyframes bounce{0%,80%,100%{transform:scale(.7)}40%{transform:scale(1)}}
  .timeline{display:flex;flex-direction:column;gap:0}
  .timeline-item{display:flex;gap:12px;padding:10px 0}
  .tl-dot{width:10px;height:10px;border-radius:50%;margin-top:4px;flex-shrink:0}
  .tl-line{width:1px;background:var(--border);flex-shrink:0;margin-left:4px}
  .tl-content{flex:1}
  .tl-title{font-size:13px;font-weight:500}
  .tl-sub{font-size:11px;color:var(--muted);margin-top:2px}
  .map-grid{display:grid;grid-template-columns:repeat(8,1fr);gap:6px}
  .room{padding:8px;border-radius:6px;text-align:center;font-size:10px;font-weight:600;cursor:pointer;transition:.2s}
  .room-free{background:#d1fae5;color:#065f46}
  .room-occ{background:#fee2e2;color:#991b1b}
  .room-you{background:var(--grad);color:#fff}
  .chip{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:500;border:1px solid var(--border);background:var(--bg);color:var(--text);cursor:pointer;transition:.2s}
  .chip:hover,.chip.active{background:var(--grad);color:#fff;border-color:transparent}
  .skeleton{background:linear-gradient(90deg,#f0f0f0 25%,#e8e8e8 37%,#f0f0f0 63%);background-size:400% 100%;animation:skeleton 1.4s ease infinite;border-radius:6px}
  @keyframes skeleton{0%{background-position:100% 50%}100%{background-position:0 50%}}
  .section{margin-bottom:24px}
  .hidden{display:none!important}
  .role-dropdown{position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid var(--border);border-radius:var(--radius-sm);z-index:200;box-shadow:0 4px 16px rgba(0,0,0,.1);margin-top:4px}
  .role-opt{padding:10px 12px;cursor:pointer;font-size:13px;font-weight:500;transition:.2s;display:flex;align-items:center;gap:8px}
  .role-opt:hover{background:#f9fafb}
  .ava-sm{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:10px;font-weight:700;flex-shrink:0}
  .profile-completion{height:6px;background:#f3f4f6;border-radius:20px;overflow:hidden;margin-top:6px}
  .upload-box{border:2px dashed var(--border);border-radius:var(--radius);padding:24px;text-align:center;cursor:pointer;transition:.2s;color:var(--muted);font-size:13px}
  .upload-box:hover{border-color:var(--accent1);background:#fafbff}
  .qr-box{width:80px;height:80px;background:var(--text);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:28px}
  .alert{padding:12px 16px;border-radius:var(--radius-sm);font-size:13px;display:flex;align-items:flex-start;gap:10px;margin-bottom:12px}
  .alert-warn{background:#fef3c7;border-left:3px solid var(--warning);color:#78350f}
  .alert-info{background:#eff6ff;border-left:3px solid var(--accent3);color:#1e40af}
  .alert-success{background:#d1fae5;border-left:3px solid var(--success);color:#065f46}
  .gpa-circle{width:80px;height:80px;position:relative}
  .gpa-text{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
  .grade-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
  .grade-row:last-child{border-bottom:none}
  .grade-letter{font-weight:700;font-size:15px}
  .grade-A{color:#059669}
  .grade-B{color:#2563eb}
  .grade-C{color:#d97706}
  .notif-panel{position:fixed;top:0;right:0;width:320px;height:100vh;background:#fff;border-left:1px solid var(--border);z-index:500;box-shadow:-4px 0 20px rgba(0,0,0,.08);transform:translateX(100%);transition:.3s;padding:20px;overflow-y:auto}
  .notif-panel.open{transform:translateX(0)}
  .overlay{position:fixed;inset:0;background:rgba(0,0,0,.2);z-index:400;opacity:0;pointer-events:none;transition:.3s}
  .overlay.open{opacity:1;pointer-events:auto}
  .notif-item{padding:12px;border-radius:var(--radius-sm);border:1px solid var(--border);margin-bottom:8px;cursor:pointer;transition:.2s}
  .notif-item:hover{background:#fafbff;border-color:var(--accent1)}
  .notif-item.unread{background:#fafbff;border-color:#c7d2fe}
  canvas{display:block}
  @media(max-width:900px){.grid-4{grid-template-columns:repeat(2,1fr)}.grid-3{grid-template-columns:1fr 1fr}.sidebar{width:60px}.sidebar:hover{width:240px}.main{margin-left:60px}.logo-text,.logo-sub,.nav-label,.user-info,.nav-item span{opacity:0;overflow:hidden;white-space:nowrap}.sidebar:hover .logo-text,.sidebar:hover .logo-sub,.sidebar:hover .nav-label,.sidebar:hover .user-info,.sidebar:hover .nav-item span{opacity:1}}
</style>
</head>
<body>

<div class="overlay" id="overlay" onclick="closeNotif()"></div>

<aside class="sidebar">
  <div class="logo">
    <div class="logo-inner">
      <div class="logo-icon">ERP</div>
      <div>
        <div class="logo-text">UniCampus</div>
        <div class="logo-sub">International Institute</div>
      </div>
    </div>
  </div>

  <div class="role-switch" style="position:relative">
    <div class="role-btn" onclick="toggleRoleDrop()">
      <span id="roleLabel">Student</span>
      <span class="role-tag tag-student" id="roleTag">Student</span>
    </div>
    <div class="role-dropdown hidden" id="roleDrop">
      <div class="role-opt" onclick="switchRole('student')"><span class="ava-sm" style="background:linear-gradient(135deg,#7c3aed,#4f46e5)">S</span>Student</div>
      <div class="role-opt" onclick="switchRole('staff')"><span class="ava-sm" style="background:linear-gradient(135deg,#2563eb,#0ea5e9)">T</span>Staff</div>
      <div class="role-opt" onclick="switchRole('admin')"><span class="ava-sm" style="background:linear-gradient(135deg,#be185d,#ec4899)">A</span>Admin</div>
    </div>
  </div>

  <nav class="nav" id="navMenu"></nav>

  <div class="sidebar-user">
    <div class="user-card">
      <div class="avatar" id="sideAvatar">AK</div>
      <div class="user-info">
        <div class="name" id="sideUser">Arjun Kumar</div>
        <div class="id" id="sideId">CS2021001</div>
        <div class="profile-completion">
          <div class="progress-fill fill-purple" style="width:82%"></div>
        </div>
      </div>
    </div>
  </div>
</aside>

<main class="main" id="mainContent">
</main>

<div class="notif-panel" id="notifPanel">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
    <div style="font-weight:600;font-size:16px">Notifications</div>
    <button class="btn btn-ghost" style="padding:4px 10px;font-size:11px" onclick="closeNotif()">Close</button>
  </div>
  <div class="notif-item unread">
    <div style="font-weight:600;font-size:13px">Exam Schedule Released</div>
    <div style="font-size:12px;color:var(--muted);margin-top:2px">End-semester exams start Dec 10, 2024</div>
    <div style="font-size:11px;color:var(--accent1);margin-top:4px">2 hours ago</div>
  </div>
  <div class="notif-item unread">
    <div style="font-weight:600;font-size:13px">Attendance Alert</div>
    <div style="font-size:12px;color:var(--muted);margin-top:2px">Your Data Structures attendance is at 68% — below minimum</div>
    <div style="font-size:11px;color:var(--danger);margin-top:4px">5 hours ago</div>
  </div>
  <div class="notif-item">
    <div style="font-weight:600;font-size:13px">Fee Payment Reminder</div>
    <div style="font-size:12px;color:var(--muted);margin-top:2px">Semester 5 fees due by Nov 30, 2024</div>
    <div style="font-size:11px;color:var(--muted);margin-top:4px">1 day ago</div>
  </div>
  <div class="notif-item">
    <div style="font-weight:600;font-size:13px">Result Published</div>
    <div style="font-size:12px;color:var(--muted);margin-top:2px">Semester 4 results are now available</div>
    <div style="font-size:11px;color:var(--muted);margin-top:4px">3 days ago</div>
  </div>
  <div class="notif-item">
    <div style="font-weight:600;font-size:13px">Timetable Updated</div>
    <div style="font-size:12px;color:var(--muted);margin-top:2px">Sem 5 timetable uploaded by the department</div>
    <div style="font-size:11px;color:var(--muted);margin-top:4px">5 days ago</div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
let currentRole='student';
let currentPage='dashboard';
let charts={};

const navConfigs={
  student:[
    {section:'Overview',items:[{id:'dashboard',icon:'🏠',label:'Dashboard'},{id:'profile',icon:'👤',label:'Profile'}]},
    {section:'Academics',items:[{id:'courses',icon:'📚',label:'Courses'},{id:'attendance',icon:'📊',label:'Attendance'},{id:'timetable',icon:'🗓️',label:'Timetable'},{id:'results',icon:'📄',label:'Results & Grades'}]},
    {section:'Campus',items:[{id:'payments',icon:'💳',label:'Payments'},{id:'campus',icon:'🏫',label:'Campus Map'},{id:'transport',icon:'🚌',label:'Transport'}]},
    {section:'Tools',items:[{id:'notifications',icon:'🔔',label:'Notifications',badge:4},{id:'ai',icon:'🤖',label:'AI Assistant'}]}
  ],
  staff:[
    {section:'Overview',items:[{id:'dashboard',icon:'🏠',label:'Dashboard'},{id:'profile',icon:'👤',label:'Profile'}]},
    {section:'Academics',items:[{id:'attendance',icon:'📊',label:'Mark Attendance'},{id:'results',icon:'📄',label:'Upload Results'},{id:'timetable',icon:'🗓️',label:'Timetable'}]},
    {section:'Communication',items:[{id:'notifications',icon:'🔔',label:'Send Notifications'},{id:'ai',icon:'🤖',label:'AI Assistant'}]}
  ],
  admin:[
    {section:'Overview',items:[{id:'dashboard',icon:'🏠',label:'Dashboard'}]},
    {section:'Management',items:[{id:'students',icon:'🎓',label:'Students'},{id:'staff',icon:'👩‍🏫',label:'Staff'},{id:'courses',icon:'📚',label:'Courses'}]},
    {section:'Academic Control',items:[{id:'timetable',icon:'🗓️',label:'Timetables'},{id:'attendance',icon:'📊',label:'Undertakings'},{id:'results',icon:'📄',label:'Results'}]},
    {section:'Infrastructure',items:[{id:'campus',icon:'🏫',label:'Rooms & Campus'},{id:'transport',icon:'🚌',label:'Transport'},{id:'payments',icon:'💳',label:'Finance'}]},
    {section:'System',items:[{id:'notifications',icon:'🔔',label:'Announcements',badge:2},{id:'ai',icon:'🤖',label:'AI Analytics'}]}
  ]
};

const userMeta={
  student:{name:'Arjun Kumar',id:'CS2021001',initials:'AK',grad:'linear-gradient(135deg,#7c3aed,#4f46e5)',roleClass:'tag-student',roleText:'Student'},
  staff:{name:'Dr. Priya Menon',id:'FAC-CS-042',initials:'PM',grad:'linear-gradient(135deg,#2563eb,#0ea5e9)',roleClass:'tag-staff',roleText:'Staff'},
  admin:{name:'Admin Singh',id:'ADMIN-001',initials:'AS',grad:'linear-gradient(135deg,#be185d,#ec4899)',roleClass:'tag-admin',roleText:'Admin'}
};

function buildNav(){
  const nav=document.getElementById('navMenu');
  nav.innerHTML='';
  (navConfigs[currentRole]||[]).forEach(section=>{
    const sec=document.createElement('div');
    sec.className='nav-section';
    sec.innerHTML=`<div class="nav-label">${section.section}</div>`;
    section.items.forEach(item=>{
      const el=document.createElement('div');
      el.className='nav-item'+(currentPage===item.id?' active':'');
      el.innerHTML=`<span class="icon">${item.icon}</span><span>${item.label}</span>${item.badge?`<span class="nav-badge">${item.badge}</span>`:''}`;
      el.onclick=()=>navigateTo(item.id);
      sec.appendChild(el);
    });
    nav.appendChild(sec);
  });
}

function navigateTo(page){
  currentPage=page;
  Object.values(charts).forEach(c=>{try{c.destroy()}catch(e){}});
  charts={};
  buildNav();
  renderPage();
}

function switchRole(role){
  currentRole=role;
  currentPage='dashboard';
  const meta=userMeta[role];
  document.getElementById('sideAvatar').textContent=meta.initials;
  document.getElementById('sideAvatar').style.background=meta.grad;
  document.getElementById('sideUser').textContent=meta.name;
  document.getElementById('sideId').textContent=meta.id;
  document.getElementById('roleLabel').textContent=meta.roleText;
  const tag=document.getElementById('roleTag');
  tag.textContent=meta.roleText;
  tag.className='role-tag '+meta.roleClass;
  document.getElementById('roleDrop').classList.add('hidden');
  buildNav();
  renderPage();
}

function toggleRoleDrop(){document.getElementById('roleDrop').classList.toggle('hidden')}

function openNotif(){document.getElementById('notifPanel').classList.add('open');document.getElementById('overlay').classList.add('open')}
