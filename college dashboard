function renderPage(){
  const el=document.getElementById('mainContent');
  const skeletons=`<div class="grid grid-4" style="margin-bottom:24px">${[...Array(4)].map(()=>`<div class="card" style="height:100px"><div class="skeleton" style="height:14px;width:60%;margin-bottom:10px"></div><div class="skeleton" style="height:28px;width:40%"></div></div>`).join('')}</div><div class="grid grid-2"><div class="card" style="height:240px"><div class="skeleton" style="height:100%"></div></div><div class="card" style="height:240px"><div class="skeleton" style="height:100%"></div></div></div>`;
  el.innerHTML=`<div class="topbar"><div><div class="page-title skeleton" style="width:200px;height:24px"></div></div></div>${skeletons}`;
  setTimeout(()=>{
    if(currentRole==='student') renderStudentPage(el);
    else if(currentRole==='staff') renderStaffPage(el);
    else renderAdminPage(el);
  },400);
}

function topbar(title,sub,extra=''){
  return `<div class="topbar"><div><div class="page-title">${title}</div><div class="page-sub">${sub}</div></div><div class="topbar-right">${extra}<button class="notif-btn" onclick="openNotif()">🔔<div class="notif-dot"></div></button></div></div>`;
}

function renderStudentPage(el){
  if(currentPage==='dashboard') el.innerHTML=topbar('Good Morning, Arjun! 👋','Thursday, November 21, 2024 — Semester 5',`<button class="btn btn-primary">📥 Download ID Card</button>`)+studentDashboard();
  else if(currentPage==='profile') el.innerHTML=topbar('My Profile','Manage your personal and academic information')+studentProfile();
  else if(currentPage==='courses') el.innerHTML=topbar('My Courses','Semester 5 — B.Tech Computer Science')+studentCourses();
  else if(currentPage==='attendance') el.innerHTML=topbar('Attendance','Track your attendance across all subjects')+studentAttendance();
  else if(currentPage==='timetable') el.innerHTML=topbar('Timetable & Exams','Your schedule for Semester 5')+studentTimetable();
  else if(currentPage==='results') el.innerHTML=topbar('Results & Answer Scripts','Academic performance overview')+studentResults();
  else if(currentPage==='payments') el.innerHTML=topbar('Fee & Payments','Manage tuition fees and payment history')+studentPayments();
  else if(currentPage==='campus') el.innerHTML=topbar('Campus Map','Room availability and campus navigation')+studentCampus();
  else if(currentPage==='transport') el.innerHTML=topbar('Transport','Bus routes and schedules')+studentTransport();
  else if(currentPage==='ai') el.innerHTML=topbar('AI Assistant','Ask anything about your academics')+studentAI();
  else if(currentPage==='notifications') el.innerHTML=topbar('Notifications','Your alerts and announcements')+studentNotifications();
  else el.innerHTML=topbar(currentPage,'—')+'<div class="card"><p style="color:var(--muted);font-size:13px">Content for this section coming soon.</p></div>';
  initCharts();
  initAI();
}

